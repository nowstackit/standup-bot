# Slack
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx   # posts the brief
SLACK_USER_TOKEN=xoxp-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxx # reads channels (no bot invite needed)
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-2.0-flash   # or gemini-2.0-pro for higher quality

# Vercel auto-injects this for Cron — set the same value in project env so the
# cron handler can verify the request came from Vercel.
CRON_SECRET=any-long-random-string
